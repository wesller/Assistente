## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.csproj.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa]rm/
[Aa]rm64/
bbin/
obj/
external/
node_modules/

# Visual Studio 2015/2017/2019/2022 cache files
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-agent.log

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper is a .NET extension
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator
DocProject/buildhelp/
DocProject/Help/*.mcgh

# ClickOnce directory
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# TODO: Comment the next line if you want to checkin your web deploy settings,
# but be aware that they might contain passwords.
*.pubxml
*.publishproj

# Generator Tools
# These are used by Visual Studio to automatically generate C# code.
# You probably don't want to check them in.
*.Designer.cs
*.Generated.cs

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet Config to suppress settings activation
# !.nuget/NuGet.Config

# Entity Framework 6+ packages
*.NuGet.props
*.NuGet.targets

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Cloud Service projects
ecf/
rcf/

# Windows Azure Guest Agent
gaget/

# Microsoft Azure Linker
*.azure.log

# Others
sql/
*.Cache
ClientBin/
[Ss]tyle[Cc]op.[Cc]ache
~*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegen.cs

# Since there are multiple workflows, keep these individual files
# as they are often patched by various tools.
node_modules/
.ntvs_analysis.dat
types_cache/

# RIA/Silverlight projects
Generated_Code/

# Backup & report files from converting an old project file
# to a newer Visual Studio version. Inspect them if you need them,
# then delete them to keep things tidy.
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptobj
*.rdl.ps

# Server Explorer connection settings
_*.dbconnection.config

# Package/publish artifacts
*.bak
*.hash
*.lastcodeanalysistlastline
*.lastcodeanalysed
*.intermediate
*.cache
*.temp

# Cake
tools/Cake/
tools/Cake.CoreCLR/

# Tabs Studio
*.tss

# Telerik
App_Data/RadSpreadProcessing/
App_Data/RadSpreadStreamProcessing/

# Local History for Visual Studio
.localhistory/

# BeatPulse
node_modules/
_beatpulse/

# Visual Studio 20th Anniversary
.vs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# AspNet5
wwwroot/lib/

# Web
*.js.map
*.css.map

# User secrets
secrets.json

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
